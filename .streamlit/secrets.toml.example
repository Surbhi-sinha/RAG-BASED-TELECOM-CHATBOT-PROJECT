# Streamlit secrets template.
#
# LOCAL DEV:   copy this file to .streamlit/secrets.toml and fill in real values
#              (that file is gitignored). Or just use a .env file — the app loads
#              both.
# STREAMLIT CLOUD: don't commit real secrets. Paste these key/value pairs into
#              the app's "Settings → Secrets" box in the Streamlit Cloud dashboard.
#              Streamlit injects them as environment variables at runtime.

GROQ_API_KEY = "your_groq_api_key_here"
HF_TOKEN = "your_huggingface_token_here"
